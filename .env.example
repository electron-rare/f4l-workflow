# Copy to .env and fill from your secret store (Infisical, launchctl env, etc.).
# Never commit .env.

# f4l-engine
PORT=9100

# Webhook auth shared with Grist + Forgejo
F4L_WEBHOOK_SECRET=__openssl_rand_hex_32__

# Bearer token accepted by /gate/advance from the CLI / cockpit
F4L_BEARER_TOKEN=__openssl_rand_hex_32__

# Grist
GRIST_API_KEY=__from_grist_user_profile__
GRIST_DOC_ID=m8eyio2PSxDMRf4RH4FHdC

# Forgejo (runner + API)
FORGEJO_TOKEN=__from_forgejo_user_settings_applications__

# life-core agent runtime
LIFE_CORE_URL=http://life-core:8000
